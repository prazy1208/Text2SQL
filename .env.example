# PostgreSQL — copy to .env and set your values
# Connection URL (SQLAlchemy/psycopg2 style)
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/postgres

# Or use separate variables:
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=your_password
# DB_NAME=text2sql_db

# ---------------------------------------------------------------------------
# LLM API keys (Intent Agent and later agents)
# Add at least one; the app uses whichever key is set (Gemini preferred if both set).
# ---------------------------------------------------------------------------

# Gemini (Google AI) — get key at https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here
# Or: GOOGLE_API_KEY=...

# OpenAI — get key at https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your_openai_key_here

# Optional: force provider when both keys are set
# LLM_PROVIDER=gemini
# LLM_PROVIDER=openai

# Optional: override default models
# GEMINI_MODEL=gemini-2.0-flash
# OPENAI_MODEL=gpt-4.1-mini
