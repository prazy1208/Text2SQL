# ---------------------------------------------------------------------------
# PostgreSQL — copy this file to .env and set values (never commit .env)
# ---------------------------------------------------------------------------
#
# Recommended for Supabase: single URI from Project Settings → Database → URI
# Example shape (use YOUR values from the dashboard):
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
#
# sslmode=require is appended automatically for *.supabase.co / pooler hosts in backend/config.py,
# or add ?sslmode=require to the URL yourself.
#
# If DATABASE_URL is set, DB_* below are ignored.
#
# DATABASE_URL=

# Or use separate variables (typical for local Postgres):
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=your_password
# DB_NAME=text2sql_db

# ---------------------------------------------------------------------------
# LLM API keys (Intent Agent and later agents)
# Add at least one; the app uses whichever key is set (Gemini preferred if both set).
# ---------------------------------------------------------------------------

# Gemini (Google AI) — https://ai.google.dev/
# GEMINI_API_KEY=your_gemini_api_key_here
# Or: GOOGLE_API_KEY=...

# OpenAI — https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your_openai_key_here

# Optional: force provider when both keys are set
# LLM_PROVIDER=gemini
# LLM_PROVIDER=openai

# Optional: override default models
# GEMINI_MODEL=gemini-2.0-flash
# OPENAI_MODEL=gpt-4.1-mini

# Optional: one-time backfill for scripts/run_backfill_session_metadata.py (browser localStorage text2sql_client_id)
# BACKFILL_CLIENT_ID=
